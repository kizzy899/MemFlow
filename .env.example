# Required for /api/collect
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini

# Optional: local collection still succeeds when Notion is not configured
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MEMFLOW_AUTH_KEY=
CHROME_CDP_URL=http://127.0.0.1:9223
OPENCLI_COMMAND=opencli
XHS_MEDIA_PROVIDER_CHAIN=browser,opencli
VIDEO_OCR_ENABLED=true
VIDEO_TRANSCRIPTION_ENABLED=true
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
VIDEO_STEP_TIMEOUT_SECONDS=180
VIDEO_MAX_DURATION_SECONDS=1800

TRANSLATION_OUTPUT_DIR=files/translated
GEMINI_API_KEY=
TRANSLATION_TASK_TIMEOUT_SECONDS=900
RAW_OUTPUT_DIR=files/raw

DATABASE_URL=sqlite:///data/app.db

PROXY_URL=

